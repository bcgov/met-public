{
  "$schema": "http://json-schema.org/draft-07/schema",
  "$id": "https://dep.gov.bc.ca/.well_known/schemas/widget_update",
  "type": "object",
  "title": "The root schema",
  "description": "The root schema comprises the entire JSON document.",
  "default": {},
  "examples": [
    {
      "title": "Who is Listening",
      "engagement_details_tab_id": null
    }
  ],
  "required": ["title"],
  "properties": {
    "title": {
      "$id": "#/properties/title",
      "type": "string",
      "title": "Widget title",
      "description": "The title of the widget.",
      "examples": ["Who is Listening"]
    },
    "engagement_details_tab_id": {
      "$id": "#/properties/engagement_details_tab_id",
      "type": ["number", "null"],
      "title": "Engagement details tab id",
      "description": "Optional details tab ID for tab-specific widgets.",
      "examples": [1, null]
    }
  }
}
